# MySQL
DB_DSN=calliope:calliope@tcp(localhost:3306)/calliope?charset=utf8mb4&parseTime=True&loc=Local
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m

# Redis（认证模块用于 Refresh Token；限流、任务队列、WS PubSub 后续依赖）
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# 七牛云对象存储（用于音频文件上传/下载）
QINIU_ACCESS_KEY=your_access_key
QINIU_SECRET_KEY=your_secret_key
QINIU_BUCKET=calliope-dev
QINIU_DOMAIN=your_bucket_test_domain    # 形如 xxxxx.bkt.clouddn.com
QINIU_REGION=z2                         # z0=华东 z1=华北 z2=华南

# App
APP_ENV=development
APP_LOG_LEVEL=debug
